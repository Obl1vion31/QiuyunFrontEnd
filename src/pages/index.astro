---
/**
 * 文件：pages/index.astro
 *
 * 【实现需求】
 * 生成网站根路径 `/` 的完整首页，把高动效首屏、六阶段工作流和系统入口组合在一起。
 *
 * 【文件职责】
 * 1. 从 data/home.ts 读取首页全部内容；
 * 2. 把首屏数据作为 Props 传给 ContentTunnel React 组件；
 * 3. 使用 Astro 模板生成后半段静态内容；
 * 4. 提供页面 Meta、全局基础样式和后半段响应式样式。
 *
 * 【关联】
 * - 数据：../data/home.ts；
 * - 交互组件：../components/ContentTunnel.tsx；
 * - 首屏样式：ContentTunnel.module.css，由 React 组件内部导入；
 * - 路由：Astro 根据本文件位置自动生成 `/`。
 *
 * 【修改入口】
 * - 文案和列表：优先修改 data/home.ts；
 * - 区块顺序和后半段 HTML：修改本文件模板；
 * - 后半段布局：修改文件末尾的全局 CSS。
 *
 * 【安全边界】
 * 不把实时业务数据或敏感信息直接写进首页；不要移除 client:load，否则首屏动画不会激活。
 */
import ContentTunnel from '../components/ContentTunnel';
import { homeContent } from '../data/home';

// ============================================================
// 1. 页面数据准备
// 【输入】homeContent 是首页唯一内容来源。
// 【输出】拆分后的变量分别交给 React Hero 和 Astro 静态区块。
// ============================================================
const { meta, hero, covers, mission, workflow, systems } = homeContent;

// 【关联】systems.entries 的 status 使用这些标签；存在 href 时则直接显示链接。
const statusLabel = {
  external: '进入',
  placeholder: '建设中',
  restricted: '授权访问',
};
---

<!doctype html>
<html lang="zh-CN">
  <head>
    {/* 2. 页面 Meta：内容来自 homeContent.meta。 */}
    <meta charset="UTF-8" />
    <meta name="description" content={meta.description} />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="theme-color" content="#10243e" />
    <title>{meta.title}</title>
  </head>
  <body>
    <main>
      {/*
        3. React Hero
        【需求】唯一的高动效区域，呈现封面隧道、平台定位、使命和当前流程。
        【关联】client:load 让 Astro 输出初始 HTML 后立即在浏览器激活 React。
      */}
      <ContentTunnel
        client:load
        covers={covers}
        stages={workflow.stages}
        eyebrow={hero.eyebrow}
        title={hero.title}
        statement={hero.statement}
        note={hero.note}
        scrollHint={hero.scrollHint}
        purposeEyebrow={mission.eyebrow}
        purposeBody={mission.body}
        boundary={mission.boundary}
      />

      {/*
        4. 六阶段工作流
        【需求】Hero 之后恢复低动效阅读，用同一份 workflow.stages 展示详细说明。
        【关联】同一数组也传给 Hero 底部轨道，确保两个区域顺序一致。
      */}
      <section class="workflow" aria-labelledby="workflow-title">
        <div class="shell workflow__inner">
          <header class="section-heading section-heading--light">
            <p>{workflow.eyebrow}</p>
            <h2 id="workflow-title">{workflow.title}</h2>
            <span>{workflow.intro}</span>
          </header>
          <ol class="workflow__track">
            {workflow.stages.map((stage, index) => (
              <li>
                <div class="workflow__marker">
                  <span>{String(index + 1).padStart(2, '0')}</span>
                  <i />
                </div>
                <div>
                  <p>{stage.label}</p>
                  <h3>{stage.verb}</h3>
                  <span>{stage.description}</span>
                </div>
              </li>
            ))}
          </ol>
          <p class="workflow__return">结果不是终点，它会沿着轨道回到下一次策划。</p>
        </div>
      </section>

      {/* 5. 系统入口：有 href 时生成链接，否则根据 status 显示当前状态。 */}
      <section class="systems shell" aria-labelledby="systems-title">
        <header class="section-heading">
          <p>{systems.eyebrow}</p>
          <h2 id="systems-title">{systems.title}</h2>
          <span>{systems.intro}</span>
        </header>
        <div class="systems__list">
          {systems.entries.map((entry) => (
            <article>
              <span>{entry.eyebrow}</span>
              <div>
                <h3>{entry.title}</h3>
                <p>{entry.summary}</p>
              </div>
              {entry.href ? (
                <a href={entry.href}>{entry.cta}<span aria-hidden="true">↗</span></a>
              ) : (
                <span class="systems__status">{statusLabel[entry.status]}</span>
              )}
            </article>
          ))}
        </div>
      </section>

      {/* 6. 页脚：更新时间来自 homeContent.meta，避免在模板中重复维护。 */}
      <footer>
        <span>QIUYUN FRONTEND</span>
        <span>最后更新 {meta.updatedAt}</span>
      </footer>
    </main>
  </body>
</html>

<style is:global>
  /*
   * 7. 全局基础变量与排版
   * 【作用范围】首页后半段与 body；首屏细节由 ContentTunnel.module.css 管理。
   * 【修改入口】颜色优先修改 :root 变量，避免在多个选择器重复替换。
   */
  :root {
    color-scheme: light;
    --paper: #f2f4ef;
    --surface: #ffffff;
    --ink: #17202a;
    --muted: #63707b;
    --line: rgba(23, 32, 42, 0.16);
    --blue: #2454d3;
    --night: #10243e;
    --orange: #ff6a3d;
    --mint: #a9ddc8;
    --max: 1180px;
  }

  * { box-sizing: border-box; }
  html { scroll-behavior: smooth; background: var(--paper); }
  body {
    margin: 0;
    color: var(--ink);
    background: var(--paper);
    font-family: 'Noto Sans CJK SC', 'Source Han Sans SC', 'PingFang SC', 'Microsoft YaHei', sans-serif;
    line-height: 1.6;
    text-rendering: optimizeLegibility;
  }
  button, a { font: inherit; }
  a { color: inherit; }
  .shell { width: min(var(--max), calc(100vw - 48px)); margin-inline: auto; }

  /* 8. 后半段通用标题：同时服务工作流与系统入口。 */
  .section-heading { max-width: 780px; }
  .section-heading > p {
    margin: 0 0 16px;
    color: var(--blue);
    font-family: ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
    font-size: 0.72rem;
    font-weight: 800;
    letter-spacing: 0.14em;
  }
  .section-heading h2 {
    margin: 0;
    font-family: 'Arial Narrow', 'Noto Sans CJK SC', 'Microsoft YaHei', sans-serif;
    font-size: clamp(2.25rem, 5.2vw, 5rem);
    font-weight: 900;
    line-height: 1.12;
    letter-spacing: -0.025em;
    text-wrap: balance;
  }
  .section-heading > span {
    display: block;
    max-width: 650px;
    margin-top: 24px;
    color: var(--muted);
    font-size: clamp(1rem, 1.45vw, 1.15rem);
  }
  .section-heading--light > p { color: #85aafa; }
  .section-heading--light > span { color: rgba(245, 248, 242, 0.64); }

  /* 9. 六阶段工作流：桌面横向排列，窄屏允许横向滚动。 */
  .workflow {
    color: #f5f8f2;
    background: var(--night);
  }
  .workflow__inner { padding-block: clamp(92px, 12vw, 160px); }
  .workflow__track {
    display: grid;
    grid-template-columns: repeat(6, minmax(150px, 1fr));
    margin: 92px 0 0;
    padding: 0 0 26px;
    overflow-x: auto;
    list-style: none;
    scrollbar-color: var(--orange) rgba(255, 255, 255, 0.1);
  }
  .workflow__track li { min-width: 160px; padding-right: 22px; }
  .workflow__marker { display: grid; grid-template-columns: auto 1fr; align-items: center; }
  .workflow__marker span {
    color: #85aafa;
    font-family: ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
    font-size: 0.72rem;
  }
  .workflow__marker i {
    position: relative;
    height: 1px;
    margin-left: 12px;
    background: rgba(255, 255, 255, 0.24);
  }
  .workflow__marker i::before {
    content: '';
    position: absolute;
    top: -4px;
    left: 0;
    width: 9px;
    height: 9px;
    border-radius: 50%;
    background: var(--orange);
  }
  .workflow__track li > div:last-child > p {
    margin: 30px 0 8px;
    color: #85aafa;
    font-size: 0.82rem;
    font-weight: 800;
  }
  .workflow__track h3 {
    min-height: 3.2em;
    margin: 0;
    font-size: clamp(1.15rem, 1.7vw, 1.45rem);
    line-height: 1.22;
  }
  .workflow__track li > div:last-child > span {
    display: block;
    margin-top: 18px;
    color: rgba(245, 248, 242, 0.6);
    font-size: 0.9rem;
  }
  .workflow__return {
    width: fit-content;
    margin: 54px 0 0 auto;
    padding-bottom: 7px;
    border-bottom: 2px solid var(--orange);
    color: rgba(245, 248, 242, 0.82);
  }

  /* 10. 系统入口：状态、外链与键盘焦点共用同一行结构。 */
  .systems { padding-block: clamp(96px, 13vw, 180px); }
  .systems__list { margin-top: 72px; border-top: 1px solid var(--ink); }
  .systems__list article {
    display: grid;
    grid-template-columns: minmax(110px, 0.28fr) minmax(0, 1fr) auto;
    gap: 28px;
    align-items: center;
    padding: 30px 0;
    border-bottom: 1px solid var(--line);
    transition: padding 180ms ease, background 180ms ease;
  }
  .systems__list article:hover { padding-inline: 16px; background: rgba(36, 84, 211, 0.04); }
  .systems__list article > span:first-child {
    color: var(--blue);
    font-family: ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
    font-size: 0.7rem;
    font-weight: 800;
  }
  .systems__list h3 { margin: 0; font-size: clamp(1.35rem, 2.2vw, 1.9rem); }
  .systems__list p { margin: 5px 0 0; color: var(--muted); }
  .systems__status, .systems__list a {
    padding: 8px 12px;
    border: 1px solid var(--line);
    color: var(--muted);
    font-size: 0.8rem;
    text-decoration: none;
  }
  .systems__list a:focus-visible { outline: 3px solid var(--orange); outline-offset: 4px; }

  footer {
    display: flex;
    justify-content: space-between;
    padding: 24px max(24px, calc((100vw - var(--max)) / 2));
    color: rgba(245, 248, 242, 0.55);
    background: #0b1a2d;
    font-family: ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
    font-size: 0.68rem;
    letter-spacing: 0.08em;
  }

  /* 11. 响应式：820px 调整平板布局，560px 改为手机单列。 */
  @media (max-width: 820px) {
    .shell { width: min(var(--max), calc(100vw - 36px)); }
    .workflow__track { margin-top: 64px; }
    .systems__list article { grid-template-columns: 86px 1fr auto; gap: 16px; }
  }

  @media (max-width: 560px) {
    .workflow__track { grid-template-columns: repeat(6, 72vw); }
    .systems__list article { grid-template-columns: 1fr auto; }
    .systems__list article > span:first-child { grid-column: 1 / -1; }
    .systems__list p { max-width: 230px; }
    footer { gap: 18px; flex-direction: column; }
  }

  /* 12. 减少动态效果：尊重操作系统设置，停用非必要平滑与过渡。 */
  @media (prefers-reduced-motion: reduce) {
    html { scroll-behavior: auto; }
    .systems__list article { transition: none; }
  }
</style>
