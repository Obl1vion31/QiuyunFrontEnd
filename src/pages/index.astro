---
// 首页页面实现文件。
// 内容来自 `src/data/home.ts`，本文件主要负责页面结构、布局和样式。
// 如果只是改文字、入口状态或更新时间，优先改 `home.ts`。
import SectionHeading from '../components/SectionHeading.astro';
import { homeContent } from '../data/home';

// 将配置拆出来，下面模板读取这些对象渲染各个页面区块。
const { meta, hero, mission, workflow, systems } = homeContent;

// 系统入口状态对应的中文标签。
// 如果在 `home.ts` 中新增 LinkStatus 类型，这里也要补充对应标签。
const statusLabel = {
  external: '外部入口',
  placeholder: '建设中',
  restricted: '授权访问',
};
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={meta.description} />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{meta.title}</title>
  </head>
  <body>
    <main>
      <section class="hero" aria-labelledby="page-title">
        <div class="hero__content">
          <p class="eyebrow">{hero.eyebrow}</p>
          <h1 id="page-title">{hero.title}</h1>
          <p class="hero__subtitle">{hero.subtitle}</p>
          <div class="hero__statement" aria-label="前端核心表达">
            {hero.statement.map((line, index) => (
              <>
                <strong>{line}</strong>
                {index < hero.statement.length - 1 && <span>并</span>}
              </>
            ))}
          </div>
          <p class="hero__note">{hero.note}</p>
          <p class="hero__updated">last updated: {meta.updatedAt}</p>
        </div>
        <div class="hero__panel" aria-label="前端作用闭环">
          <div class="loop-card">
            <span>闭环</span>
            <strong>{hero.loopTitle}</strong>
          </div>
          <ol class="hero-loop">
            {hero.loop.map(([title, body], index) => (
              <li>
                <span>{String(index + 1).padStart(2, '0')}</span>
                <div>
                  <strong>{title}</strong>
                  <p>{body}</p>
                </div>
              </li>
            ))}
          </ol>
          <p class="loop-note">每一次内容发布，都应回到下一轮选题、视觉和触点优化。</p>
        </div>
      </section>

      <section class="section mission" id="mission">
        <SectionHeading number={mission.sectionNo} title={mission.title} />
        <p class="mission__intro"><strong>{mission.label}</strong>{mission.body}</p>
        <div class="mission__grid mission__grid--goals">
          <div class="goal-grid">
            {mission.goals.map((goal, index) => (
              <article class="goal-card">
                <span>{String(index + 1).padStart(2, '0')}</span>
                <h3>{goal.title}</h3>
                <strong>{goal.lead}</strong>
                <p>{goal.body}</p>
              </article>
            ))}
          </div>
        </div>
        <aside class="boundary">
          <strong>前端边界</strong>
          <p>{mission.boundary}</p>
        </aside>
      </section>

      <section class="section workflow" id="workflow">
        <SectionHeading number={workflow.sectionNo} title={workflow.title} subtitle={workflow.subtitle} />
        <p class="section-intro">{workflow.intro}</p>
        <div class="workflow__grid">
          <ol class="timeline">
            {workflow.steps.map((step, index) => (
              <li>
                <span class="timeline__index">{String(index + 1).padStart(2, '0')}</span>
                <div>
                  <h3>{step.action}</h3>
                  <span class="timeline__owner">{step.owner}</span>
                  <p>{step.description}</p>
                </div>
              </li>
            ))}
          </ol>
          <aside class="foundation">
            <h3>链路的执行底座</h3>
            <p>规则不单独漂浮，而是跟着岗位、项目和内容类型进入具体环节。</p>
            {workflow.foundations.map((item) => (
              <article>
                <strong>{item.title}</strong>
                <span>{item.body}</span>
              </article>
            ))}
          </aside>
        </div>
        <div class="role-strip" aria-label="岗位在链路中的位置">
          {workflow.roles.map(([role, description]) => (
            <article>
              <strong>{role}</strong>
              <span>{description}</span>
            </article>
          ))}
        </div>
      </section>

      <section class="section systems" id="systems">
        <SectionHeading number={systems.sectionNo} title={systems.title} subtitle={systems.subtitle} align="center" />
        <div class="systems__grid">
          {systems.entries.map((entry) => (
            <article class:list={['system-card', `system-card--${entry.status}`]}>
              <div class="system-card__top">
                <span>{entry.eyebrow}</span>
                <small>{statusLabel[entry.status]}</small>
              </div>
              <h3>{entry.title}</h3>
              <p>{entry.summary}</p>
              <ul>
                {entry.scope.map((item) => <li>{item}</li>)}
              </ul>
              {entry.href ? (
                <a href={entry.href}>{entry.cta} ↗</a>
              ) : (
                <button type="button" disabled>{entry.cta} · {statusLabel[entry.status]}</button>
              )}
            </article>
          ))}
        </div>
      </section>
    </main>
  </body>
</html>

<style is:global>
  /*
    全局设计变量：
    - --max 控制页面最大内容宽度；
    - --gold / --night 控制当前首页主视觉色；
    - 后续如果要建立完整 design tokens，可从这里抽离。
  */
  :root {
    color-scheme: light;
    --bg: #f5f2eb;
    --surface: #fffdf8;
    --ink: #1d232b;
    --muted: #68717d;
    --line: rgba(30, 38, 49, 0.12);
    --gold: #b8893b;
    --gold-dark: #7f5619;
    --cream: #fff3cf;
    --warm-gray: #e8ded0;
    --max: 1180px;
  }

  /* 基础重置，保证盒模型和滚动行为稳定。 */
  * {
    box-sizing: border-box;
  }

  html {
    scroll-behavior: smooth;
  }

  /* 页面主体字体栈：优先系统字体，并兼顾中文系统字体。 */
  body {
    margin: 0;
    color: var(--ink);
    background: var(--bg);
    font-family:
      Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI",
      "PingFang SC", "Microsoft YaHei", sans-serif;
    line-height: 1.6;
  }

  button,
  a {
    font: inherit;
  }

  /* Hero 首屏布局。当前采用浅暖色背景，降低压迫感。 */
  .hero {
    min-height: 88vh;
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(320px, 0.86fr);
    gap: 56px;
    align-items: center;
    padding: clamp(58px, 8vw, 104px) max(24px, calc((100vw - var(--max)) / 2));
    color: var(--ink);
    background:
      radial-gradient(circle at 88% 18%, rgba(255, 216, 128, 0.42), transparent 32%),
      linear-gradient(135deg, #fff9e9 0%, #f4eadb 48%, #eee5d7 100%);
  }

  /* 英文辅助标题和小标签的共用样式。 */
  .eyebrow,
  .loop-card span {
    margin: 0;
    color: var(--gold-dark);
    font-size: 0.78rem;
    font-weight: 800;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  /* Hero 主标题：控制字号和行长，避免压满首屏。 */
  h1 {
    max-width: 720px;
    margin: 20px 0 0;
    font-size: clamp(2.75rem, 6vw, 5.2rem);
    line-height: 1.04;
    letter-spacing: 0;
  }

  .hero__subtitle {
    margin: 18px 0 0;
    color: #776d5f;
    font-size: clamp(1.02rem, 1.7vw, 1.28rem);
  }

  /* Hero 核心三句表达。保持重点，但不做高对比重压。 */
  .hero__statement {
    display: grid;
    gap: 10px;
    max-width: 620px;
    margin: 36px 0 0;
    padding: 22px 24px;
    border: 1px solid rgba(184, 137, 59, 0.24);
    background: rgba(255, 253, 247, 0.58);
  }

  .hero__statement strong {
    color: #7a4f12;
    font-size: clamp(1.25rem, 2.2vw, 1.9rem);
    line-height: 1.25;
  }

  .hero__statement span {
    color: #a1917b;
    font-size: 0.96rem;
  }

  .hero__note {
    max-width: 660px;
    margin: 28px 0 0;
    color: #625a50;
    font-size: 1.02rem;
  }

  .hero__updated {
    margin: 24px 0 0;
    color: #9a8d7b;
    font-size: 0.85rem;
  }

  /* Hero 右侧闭环面板，解释前端作用，而不是只堆装饰词。 */
  .hero__panel {
    min-height: 500px;
    display: grid;
    align-content: center;
    gap: 18px;
    padding: 30px;
    border: 1px solid rgba(80, 65, 45, 0.12);
    background: rgba(255, 253, 247, 0.72);
    box-shadow: 0 24px 70px rgba(94, 75, 47, 0.1);
  }

  .loop-card {
    padding: 22px;
    border: 1px solid rgba(184, 137, 59, 0.22);
    background: var(--cream);
  }

  .loop-card strong {
    display: block;
    margin-top: 8px;
    font-size: clamp(1.35rem, 2.5vw, 1.9rem);
    line-height: 1.25;
  }

  .hero-loop {
    display: grid;
    gap: 12px;
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .hero-loop li {
    display: grid;
    grid-template-columns: 42px 1fr;
    gap: 14px;
    align-items: start;
    padding: 16px;
    border: 1px solid rgba(30, 38, 49, 0.09);
    background: rgba(255, 255, 255, 0.58);
  }

  .hero-loop li > span {
    display: grid;
    width: 34px;
    height: 34px;
    place-items: center;
    color: var(--gold-dark);
    border: 1px solid rgba(184, 137, 59, 0.3);
    background: rgba(184, 137, 59, 0.09);
    font-weight: 800;
  }

  .hero-loop strong {
    display: block;
    color: var(--ink);
    font-size: 1.04rem;
  }

  .hero-loop p,
  .loop-note {
    margin: 6px 0 0;
    color: var(--muted);
    font-size: 0.94rem;
  }

  .loop-note {
    padding-top: 12px;
    border-top: 1px solid rgba(30, 38, 49, 0.08);
  }

  /* 通用页面区块容器，控制最大宽度和上下留白。 */
  .section {
    width: min(var(--max), calc(100vw - 40px));
    margin: 0 auto;
    padding: clamp(72px, 9vw, 118px) 0;
  }

  /* 使命区块：用轻量引导文字连接四阶段目标，避免形成沉重文字墙。 */
  .mission__intro {
    max-width: 780px;
    margin: 20px 0 0;
    color: #4f5963;
    font-size: clamp(0.98rem, 1.4vw, 1.08rem);
  }

  .mission__intro strong {
    color: var(--ink);
  }

  .mission__grid {
    margin-top: 34px;
  }

  .goal-card,
  .foundation,
  .system-card {
    border: 1px solid var(--line);
    background: var(--surface);
  }

  .goal-card p,
  .foundation p,
  .system-card p {
    color: var(--muted);
  }

  /* 递进目标卡片网格。 */
  .goal-grid {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 14px;
  }

  .goal-card {
    min-height: 206px;
    padding: 24px;
  }

  .goal-card span {
    color: var(--gold);
    font-weight: 800;
  }

  .goal-card h3 {
    margin: 16px 0 8px;
    font-size: 1.24rem;
  }

  .goal-card strong {
    color: var(--ink);
  }

  /* 前端边界提示条，用于强调“前端不直接承担最终销售成交”。 */
  .boundary {
    margin-top: 22px;
    padding: 20px 24px;
    border: 1px solid rgba(184, 137, 59, 0.2);
    border-left: 4px solid var(--gold);
    background: rgba(255, 244, 218, 0.66);
  }

  .boundary p {
    margin: 8px 0 0;
    color: #5d5549;
  }

  .section-intro {
    max-width: 720px;
    color: var(--muted);
    font-size: 1.08rem;
  }

  /* 协作链路：左侧 timeline，右侧执行底座。 */
  .workflow__grid {
    display: grid;
    grid-template-columns: minmax(0, 1.2fr) minmax(300px, 0.8fr);
    gap: 34px;
    margin-top: 40px;
  }

  /* 纵向流程轴，每个 li 对应一个链路节点。 */
  .timeline {
    display: grid;
    gap: 12px;
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .timeline li {
    display: grid;
    grid-template-columns: 56px 1fr;
    gap: 20px;
    align-items: start;
    padding: 22px 24px;
    border: 1px solid var(--line);
    background: rgba(255, 253, 248, 0.72);
  }

  .timeline__index {
    display: grid;
    width: 44px;
    height: 44px;
    place-items: center;
    color: var(--gold-dark);
    border: 1px solid rgba(184, 137, 59, 0.35);
    background: rgba(184, 137, 59, 0.11);
    font-weight: 800;
  }

  .timeline h3,
  .foundation h3,
  .system-card h3 {
    margin: 0;
  }

  .timeline p {
    margin: 8px 0 0;
    color: var(--muted);
  }

  .timeline h3 {
    font-size: clamp(1.18rem, 2vw, 1.52rem);
    line-height: 1.25;
  }

  .timeline__owner {
    display: inline-flex;
    margin-top: 8px;
    color: var(--gold-dark);
    font-size: 0.88rem;
    font-weight: 800;
  }

  /* 执行底座卡片。桌面端 sticky，方便长链路阅读时保持上下文。 */
  .foundation {
    align-self: start;
    padding: 30px;
    position: sticky;
    top: 28px;
  }

  .foundation article {
    display: grid;
    gap: 6px;
    padding: 18px 0;
    border-top: 1px solid var(--line);
  }

  .foundation article span {
    color: var(--muted);
  }

  /* 岗位摘要条，补充说明岗位在链路中的位置。 */
  .role-strip {
    display: grid;
    grid-template-columns: repeat(5, minmax(0, 1fr));
    gap: 12px;
    margin-top: 24px;
  }

  .role-strip article {
    padding: 18px;
    background: #242c35;
    color: #f8f2e6;
  }

  .role-strip span {
    display: block;
    margin-top: 8px;
    color: #c4bdaf;
    font-size: 0.92rem;
  }

  /* 系统入口卡片区。三列在桌面端展示，移动端改为单列。 */
  .systems__grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 18px;
    margin-top: 42px;
  }

  /* 入口卡片基础样式。 */
  .system-card {
    display: flex;
    min-height: 560px;
    flex-direction: column;
    padding: 28px;
  }

  /* 授权入口使用更暖的背景，提示敏感信息边界。 */
  .system-card--restricted {
    border-color: rgba(184, 137, 59, 0.45);
    background: #fff9eb;
  }

  .system-card__top {
    display: flex;
    justify-content: space-between;
    gap: 12px;
    color: var(--gold-dark);
    font-size: 0.78rem;
    font-weight: 800;
  }

  .system-card small {
    color: #8d8273;
    font-size: 0.78rem;
  }

  .system-card h3 {
    margin-top: 26px;
    font-size: 1.7rem;
  }

  .system-card ul {
    display: grid;
    gap: 10px;
    margin: 24px 0 28px;
    padding-left: 18px;
    color: #4e5965;
  }

  .system-card button,
  .system-card a {
    display: inline-flex;
    justify-content: center;
    width: 100%;
    margin-top: auto;
    padding: 13px 16px;
    border: 1px solid #26313d;
    color: #f8f2e6;
    background: #26313d;
    text-decoration: none;
    cursor: default;
  }

  .system-card button:disabled {
    opacity: 1;
  }

  /* 平板以下：主要布局从多列改成单列。 */
  @media (max-width: 980px) {
    .hero,
    .workflow__grid {
      grid-template-columns: 1fr;
    }

    .hero {
      min-height: auto;
    }

    .hero__panel {
      min-height: 360px;
    }

    .systems__grid {
      grid-template-columns: 1fr;
    }

    .goal-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .system-card {
      min-height: auto;
    }

    .role-strip {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .foundation {
      position: static;
    }
  }

  /* 手机端：收紧页面留白，确保中文长句不横向溢出。 */
  @media (max-width: 640px) {
    .hero {
      padding: 46px 20px 54px;
    }

    .hero__statement {
      margin-top: 34px;
    }

    .section {
      width: min(100% - 28px, var(--max));
      padding: 62px 0;
    }

    .goal-grid,
    .role-strip {
      grid-template-columns: 1fr;
    }

    .timeline li {
      grid-template-columns: 1fr;
    }
  }
</style>
