---
// 通用区块标题组件。
// 用于首页中“我们为什么存在 / 前端如何运作 / 接下来从哪里进入”等大区块标题。
interface Props {
  // 区块编号，例如 01、02、03；不传则不显示编号标签。
  number?: string;
  // 区块主标题。
  title: string;
  // 区块副标题或解释说明；不传则不显示说明。
  subtitle?: string;
  // 标题对齐方式。首页系统入口区使用 center，其余区块默认 left。
  align?: 'left' | 'center';
}

// 设置默认左对齐，避免每次使用组件都重复传 align="left"。
const { number, title, subtitle, align = 'left' } = Astro.props;
---

<header class:list={['section-heading', align === 'center' && 'section-heading--center']}>
  {number && <span class="section-heading__number">{number}</span>}
  <h2>{title}</h2>
  {subtitle && <p>{subtitle}</p>}
</header>

<style>
  /* 控制标题区域最大宽度，避免中文长标题阅读跨度过宽。 */
  .section-heading {
    max-width: 760px;
  }

  /* 居中版本用于页面中需要强调的独立区块标题。 */
  .section-heading--center {
    margin-inline: auto;
    text-align: center;
  }

  /* 小编号标签，帮助用户理解页面的阅读阶段。 */
  .section-heading__number {
    display: inline-flex;
    align-items: center;
    min-height: 28px;
    padding: 0 12px;
    border: 1px solid rgba(183, 148, 82, 0.35);
    color: #9d7430;
    background: rgba(183, 148, 82, 0.1);
    font-size: 0.76rem;
    font-weight: 700;
    letter-spacing: 0.08em;
  }

  /* 区块主标题，使用响应式字号。 */
  h2 {
    margin: 18px 0 0;
    color: #1d232b;
    font-size: clamp(2rem, 4vw, 3.4rem);
    line-height: 1.1;
    letter-spacing: 0;
  }

  /* 区块副标题，承担解释作用，不参与主视觉竞争。 */
  p {
    margin: 14px 0 0;
    color: #68717d;
    font-size: 1.04rem;
    line-height: 1.75;
  }
</style>
